#!/usr/bin/env zsh

# Configuration
subsystem="xyz.hribar.torrentaut"
util="ServiceStop"

# Our own logging utility
logBin="/usr/local/bin/bhlog"

# --- FUNCTION: Log Event ---
logEvent() {
  local msg="${1}"
  local timestamp

  # 1. Get the timestamp
  if (( $+commands[gdate] )); then
    timestamp=$(gdate '+%Y-%m-%d %H:%M:%S.%6N')
  else
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
  fi

  # 2. Print to standard out (for debug/console logs)
  echo "[${timestamp}] ${subsystem} ${util:-Service} [PPID:${$}] ${msg}"

  # 3. Call the logging utility
  if [[ -x "${logBin}" ]]; then
    "${logBin}" "${subsystem}" "${util:-Service}" "[PPID:${$}] ${msg}"
  fi
}

# 1. Stopping service
logEvent "Stopping service '${subsystem}'..."
launchctl bootout gui/$(id -u)/${subsystem} 2>/dev/null || true

logEvent "✅ Done."
